<DModal @title={{this.modalTitle}} class="discourse-size-edit-character-modal">
  <:body>
    <div onkeydown={{this.onKeyDown}}>
      <div class="control-group">
        <label>{{i18n "discourse_size.modes.title"}}</label>
        {{#if @model.isNew}}
          <span class="instructions">{{i18n "discourse_size.modes.help"}}</span>
          <div class="type-selection">
            <label class="radio-label">
              <input
                type="radio"
                name="char_type"
                value="game"
                checked={{eq this.characterType "game"}}
                {{on "change" (fn this.setCharType "game")}}
              />
              <span><strong>{{i18n "discourse_size.modes.game_name"}}</strong>:
                {{i18n "discourse_size.modes.game_desc"}}</span>
            </label>
            <label class="radio-label">
              <input
                type="radio"
                name="char_type"
                value="freeform"
                checked={{eq this.characterType "freeform"}}
                {{on "change" (fn this.setCharType "freeform")}}
              />
              <span><strong>{{i18n
                    "discourse_size.modes.freeform_name"
                  }}</strong>:
                {{i18n "discourse_size.modes.freeform_desc"}}</span>
            </label>
          </div>
        {{else}}
          <div class="type-display">
            <span class="mode-label">Mode:</span>
            <strong>{{if
                (eq this.characterType "game")
                (i18n "discourse_size.modes.game_name")
                (i18n "discourse_size.modes.freeform_name")
              }}</strong>
            <span class="instructions">{{i18n
                "discourse_size.modes.cannot_change"
              }}</span>
          </div>
        {{/if}}
      </div>

      <hr />

      <div class="control-group">
        <label>{{i18n "discourse_size.fields.name"}}</label>
        <span class="instructions">{{i18n
            "discourse_size.fields.name_help"
          }}</span>
        <Input @type="text" @value={{this.name}} />
      </div>

      <div class="control-group">
        <label>{{i18n "discourse_size.fields.picture"}}</label>
        <div class="picture-upload-wrapper">
          {{#if this.picture}}
            <img src={{this.picture}} alt="Preview" class="upload-preview" />
          {{/if}}
          <div class="upload-controls">
            <DButton
              @action={{this.uploadImage}}
              @label="discourse_size.upload_picture"
              @icon="upload"
              class="btn-default"
            />
          </div>
        </div>
      </div>

      <div class="control-group">
        <label>{{i18n "discourse_size.gender"}}</label>
        <Input
          @type="text"
          @value={{this.gender}}
          placeholder="e.g. Male, Female, Non-binary"
        />
      </div>

      <div class="control-group">
        <label>{{i18n "discourse_size.pronouns"}}</label>
        <Input
          @type="text"
          @value={{this.pronouns}}
          placeholder="e.g. He/Him, She/Her, They/Them"
        />
      </div>

      <div class="control-group">
        <label>{{i18n "discourse_size.age"}}</label>
        <Input
          @type="text"
          @value={{this.age}}
          placeholder="e.g. 25, Young Adult, Adult"
        />
      </div>

      <div class="control-group">
        <label>{{i18n "discourse_size.species"}}</label>
        <Input
          @type="text"
          @value={{this.species}}
          placeholder="e.g. Human, Elf, Dragon"
        />
      </div>

      <div class="control-group">
        <label>{{i18n "discourse_size.description"}}</label>
        <span class="instructions">{{i18n
            "discourse_size.fields.description_help"
          }}</span>
        <Textarea
          @value={{this.description}}
          class="character-description-input"
        />
      </div>

      <div class="control-group">
        <label>{{i18n "discourse_size.fields.info_url"}}</label>
        <span class="instructions">{{i18n
            "discourse_size.fields.info_url_help"
          }}</span>
        <Input
          @type="text"
          @value={{this.infoPost}}
          placeholder="https://..."
          class="info-post-input"
        />
      </div>

      <hr />

      <div class="control-group">
        <label>{{if
            (eq this.characterType "freeform")
            (i18n "discourse_size.fields.size")
            (i18n "discourse_size.fields.base_size")
          }}</label>
        <span class="instructions">{{if
            (eq this.characterType "freeform")
            (i18n "discourse_size.fields.size_help")
            (i18n "discourse_size.fields.base_size_help")
          }}</span>
        <div class="size-input-wrapper">
          <input
            type="number"
            value={{this.displaySize}}
            step="0.0001"
            class="base-size-input"
            {{on "input" this.onBaseSizeInput}}
            {{on "blur" this.onBaseSizeBlur}}
          />
          <select
            class="size-unit-selector"
            {{on "change" (action "onUnitChange" value="target.value")}}
          >
            {{#each this.units as |unit|}}
              <option value={{unit.id}} selected={{eq this.sizeUnit unit.id}}>
                {{unit.name}}
              </option>
            {{/each}}
          </select>
        </div>
        {{#if this.sizeError}}
          <div class="inline-error">{{this.sizeError}}</div>
        {{/if}}
      </div>

      <div class="control-group">
        <label>{{i18n "discourse_size.fields.measurement_system"}}</label>
        <span class="instructions">{{i18n
            "discourse_size.fields.measurement_system_help"
          }}</span>
        <select
          onchange={{action (mut this.measurementSystem) value="target.value"}}
        >
          <option
            value="imperial"
            selected={{eq this.measurementSystem "imperial"}}
          >{{i18n "discourse_size.measurement_system_imperial"}}</option>
          <option
            value="metric"
            selected={{eq this.measurementSystem "metric"}}
          >{{i18n "discourse_size.measurement_system_metric"}}</option>
        </select>
      </div>

      <hr />

      {{#if (not (eq this.characterType "freeform"))}}
        <div class="control-group blocking-items-group">
          <label>{{i18n "discourse_size.blocking.block_items"}}</label>
          <span class="instructions">{{i18n
              "discourse_size.blocking.select_items_to_block"
            }}</span>
          <div class="bulk-buttons">
            <DButton
              @action={{this.blockAll}}
              @label="discourse_size.blocking.block_all"
              class="btn-small
                {{if (eq this.blockingMode 'all') 'btn-primary'}}
                {{if (not (eq this.blockingMode 'all')) 'btn-default'}}"
            />
            <DButton
              @action={{this.blockNone}}
              @label="discourse_size.blocking.block_none"
              class="btn-small
                {{if (eq this.blockingMode 'none') 'btn-primary'}}
                {{if (not (eq this.blockingMode 'none')) 'btn-default'}}"
            />
            <DButton
              @action={{this.blockAllGrowing}}
              @label="discourse_size.blocking.block_all_growing"
              class="btn-small
                {{if (eq this.blockingMode 'growing') 'btn-primary'}}
                {{if (not (eq this.blockingMode 'growing')) 'btn-default'}}"
            />
            <DButton
              @action={{this.blockAllShrinking}}
              @label="discourse_size.blocking.block_all_shrinking"
              class="btn-small
                {{if (eq this.blockingMode 'shrinking') 'btn-primary'}}
                {{if (not (eq this.blockingMode 'shrinking')) 'btn-default'}}"
            />
          </div>

          {{#if this.growingItems.length}}
            <div class="blocking-section">
              <span class="section-title">{{i18n
                  "discourse_size.blocking.growing_items"
                }}</span>
              <div class="blocking-items-grid">
                {{#each this.growingItems as |item|}}
                  <label
                    class="blocking-item-card
                      {{if (this.isItemBlocked item.key) 'blocked'}}"
                  >
                    <input
                      type="checkbox"
                      checked={{this.isItemBlocked item.key}}
                      {{on "change" (fn this.toggleItemBlock item.key)}}
                    />
                    {{d-icon "angle-double-up" class="grow-icon"}}
                    <span>{{item.name}}</span>
                  </label>
                {{/each}}
              </div>
            </div>
          {{/if}}

          {{#if this.shrinkingItems.length}}
            <div class="blocking-section">
              <span class="section-title">{{i18n
                  "discourse_size.blocking.shrinking_items"
                }}</span>
              <div class="blocking-items-grid">
                {{#each this.shrinkingItems as |item|}}
                  <label
                    class="blocking-item-card
                      {{if (this.isItemBlocked item.key) 'blocked'}}"
                  >
                    <input
                      type="checkbox"
                      checked={{this.isItemBlocked item.key}}
                      {{on "change" (fn this.toggleItemBlock item.key)}}
                    />
                    {{d-icon "angle-double-down" class="shrink-icon"}}
                    <span>{{item.name}}</span>
                  </label>
                {{/each}}
              </div>
            </div>
          {{/if}}
        </div>

        <div class="control-group blocking-users-group">
          <label>{{i18n "discourse_size.blocking.blocked_users_list"}}</label>
          <div class="user-search-wrapper">
            <EmailGroupUserChooser
              @onChange={{this.onUserSelected}}
              @options={{hash maximum=1}}
              @placeholderKey="discourse_size.blocking.username_placeholder"
            />
          </div>

          {{#if this.blockedUsers.length}}
            <div class="blocked-users-list">
              {{#each this.blockedUsers as |user|}}
                <div class="blocked-user-item">
                  <div class="user-info">
                    {{avatar user imageSize="small"}}
                    <span class="username">{{user.username}}</span>
                  </div>
                  <DButton
                    @action={{fn this.unblockUser user.id}}
                    @label="discourse_size.blocking.unblock_user"
                    class="btn-flat btn-danger unblock-btn"
                  />
                </div>
              {{/each}}
            </div>
          {{else}}
            <div class="empty-notice">{{i18n
                "discourse_size.blocking.no_blocked_users"
              }}</div>
          {{/if}}
        </div>
      {{/if}}

      <hr />

      <div class="control-group checkbox-group">
        <label>{{i18n "discourse_size.options.title"}}</label>

        <div class="control-group checkbox-group">
          <label>
            <Input @type="checkbox" @checked={{this.showComparison}} />
            {{i18n "discourse_size.options.show_comparison"}}
          </label>
        </div>

        <div class="control-group checkbox-group">
          <label>
            <Input @type="checkbox" @checked={{this.isMain}} />
            {{i18n "discourse_size.options.is_main"}}
          </label>
          <span class="instructions">
            {{i18n "discourse_size.options.is_main_help"}}
          </span>
        </div>
      </div>

    </div>
  </:body>
  <:footer>
    <DButton
      @action={{this.save}}
      @label="discourse_size.save"
      @disabled={{or this.isSaving this.isInvalid}}
      class="btn-primary"
    />
    <DButton
      @action={{this.close}}
      @label="discourse_size.cancel"
      class="btn-default"
    />
    {{#unless @model.isNew}}
      <DButton
        @action={{this.deleteCharacter}}
        @label="discourse_size.delete"
        class="btn-danger modal-delete-btn"
      />
    {{/unless}}
  </:footer>
</DModal>