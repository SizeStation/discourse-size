<DModal
  @title={{this.modalTitle}}
  @closeModal={{@closeModal}}
  class="discourse-size-edit-character-modal"
>
  <:body>
    <div onkeydown={{this.onKeyDown}}>
      <div class="control-group">
        <label>Character Mode</label>
        {{#if @model.isNew}}
          <span class="instructions">Choose how your character's size is
            managed.
            <strong>This cannot be changed later.</strong></span>
          <div class="type-selection">
            <label class="radio-label">
              <input
                type="radio"
                name="char_type"
                value="game"
                checked={{eq this.characterType "game"}}
                {{on "change" (fn this.setCharType "game")}}
              />
              <span><strong>Game Mode</strong>: earn and use coins to grow or
                shrink your character, or let others grow/shrink your character.</span>
            </label>
            <label class="radio-label">
              <input
                type="radio"
                name="char_type"
                value="freeform"
                checked={{eq this.characterType "freeform"}}
                {{on "change" (fn this.setCharType "freeform")}}
              />
              <span><strong>Freeform Mode</strong>: manually set your
                character's size to any number, no growing/shrinking.</span>
            </label>
          </div>
        {{else}}
          <div class="type-display">
            <span class="mode-label">Mode:</span>
            <strong>{{if
                (eq this.characterType "game")
                "Game Mode"
                "Freeform Mode"
              }}</strong>
            <span class="instructions">(Mode cannot be changed after creation)</span>
          </div>
        {{/if}}
      </div>

      <div class="control-group">
        <label>Name</label>
        <span class="instructions">What is this character called?</span>
        <Input @type="text" @value={{this.name}} />
      </div>

      <div class="control-group">
        <label>Picture</label>
        <div class="picture-upload-wrapper">
          {{#if this.picture}}
            <img src={{this.picture}} alt="Preview" class="upload-preview" />
          {{/if}}
          <div class="upload-controls">
            <DButton
              @action={{this.uploadImage}}
              @label="discourse_size.upload_picture"
              @icon="upload"
              class="btn-default"
            />
          </div>
        </div>
      </div>

      <div class="control-group">
        <label>{{i18n "discourse_size.gender"}}</label>
        <Input
          @type="text"
          @value={{this.gender}}
          placeholder="e.g. Male, Female, Non-binary"
        />
      </div>

      <div class="control-group">
        <label>{{i18n "discourse_size.pronouns"}}</label>
        <Input
          @type="text"
          @value={{this.pronouns}}
          placeholder="e.g. He/Him, She/Her, They/Them"
        />
      </div>

      <div class="control-group">
        <label>{{i18n "discourse_size.age"}}</label>
        <Input
          @type="text"
          @value={{this.age}}
          placeholder="e.g. 25, Young Adult, Adult"
        />
      </div>

      <div class="control-group">
        <label>{{i18n "discourse_size.description"}}</label>
        <span class="instructions">Tell us more about this character's
          personality or backstory.</span>
        <Textarea
          @value={{this.description}}
          class="character-description-input"
        />
      </div>

      <div class="control-group">
        <label>Info URL</label>
        <span class="instructions">A link to a forum post or external page with
          more information about this character.</span>
        <Input
          @type="text"
          @value={{this.infoPost}}
          placeholder="https://..."
          class="info-post-input"
        />
      </div>

      <div class="control-group">
        <label>{{if
            (eq this.characterType "freeform")
            "Size (cm)"
            "Base Size (cm)"
          }}</label>
        <span class="instructions">{{if
            (eq this.characterType "freeform")
            "The current size of the character."
            "The initial size of the character."
          }}</span>
        <input
          type="number"
          value={{this.baseSize}}
          step="0.1"
          min={{if (eq this.characterType "game") this.siteSettings.discourse_size_min_base_size "0.1"}}
          max={{if (eq this.characterType "game") this.siteSettings.discourse_size_max_base_size}}
          class="base-size-input"
          {{on "input" this.onBaseSizeInput}}
          {{on "blur" this.onBaseSizeBlur}}
        />
        {{#if this.sizeError}}
          <div class="inline-error">{{this.sizeError}}</div>
        {{/if}}
      </div>

      <div class="control-group">
        <label>Measurement System</label>
        <span class="instructions">How sizes should be displayed for this
          character.</span>
        <select
          onchange={{action (mut this.measurementSystem) value="target.value"}}
        >
          <option
            value="imperial"
            selected={{eq this.measurementSystem "imperial"}}
          >Imperial (ft/in/mi)</option>
          <option
            value="metric"
            selected={{eq this.measurementSystem "metric"}}
          >Metric (cm/m/km)</option>
        </select>
      </div>

      {{#if (not (eq this.characterType "freeform"))}}
        <div class="control-group checkbox-group">
          <label>
            <Input @type="checkbox" @checked={{this.allowGrowth}} />
            Allow others to grow this character
          </label>
        </div>

        <div class="control-group checkbox-group">
          <label>
            <Input @type="checkbox" @checked={{this.allowShrink}} />
            Allow others to shrink this character
          </label>
        </div>
      {{/if}}

      <div class="control-group checkbox-group">
        <label>
          <Input @type="checkbox" @checked={{this.showComparison}} />
          Show size comparison text
        </label>
      </div>

      <div class="control-group checkbox-group">
        <label>
          <Input @type="checkbox" @checked={{this.isMain}} />
          Set as main character
        </label>
        <span class="instructions">
          Your main character appears on your profile card and user page.
        </span>
      </div>

    </div>
  </:body>
  <:footer>
    <DButton
      @action={{this.save}}
      @label="discourse_size.save"
      @disabled={{or this.isSaving this.isInvalid}}
      class="btn-primary"
    />
    <DButton
      @action={{@closeModal}}
      @label="discourse_size.cancel"
      class="btn-default"
    />
    {{#unless @model.isNew}}
      <DButton
        @action={{this.deleteCharacter}}
        @label="discourse_size.delete"
        class="btn-danger modal-delete-btn"
      />
    {{/unless}}
  </:footer>
</DModal>