<div class="discourse-size-character-card {{if @character.is_main 'is-main'}}">
  <div class="character-header-layout">
    {{#if @character.picture}}
      <div class="character-picture-wrapper">
        <div
          class="ping-effect
            {{if (eq this.activeActionType 'grow') 'growing'}}
            {{if (eq this.activeActionType 'shrink') 'shrinking'}}"
          style={{html-safe
            (concat
              "background-image: url("
              @character.picture
              "); "
              this.pingStyle
            )
          }}
        ></div>

        <img
          src={{@character.picture}}
          alt={{@character.name}}
          class="character-picture"
        />

        {{#each this.floatingWords as |word|}}
          <span
            class="floating-word {{word.type}}"
            style={{html-safe word.style}}
          >
            {{word.text}}
          </span>
        {{/each}}

        {{#if this.thrownItem}}
          <div
            class="thrown-item-effect"
            style={{html-safe
              (concat
                "--startX: "
                this.thrownItem.startX
                "; --startY: "
                this.thrownItem.startY
                ";"
              )
            }}
          >
            <img src={{this.thrownItem.picture}} alt="" />
          </div>
        {{/if}}
      </div>
    {{/if}}

    <div class="character-info">
      <div class="character-title-row">
        <h2>
          <strong>{{@character.name}}</strong>
          {{#if @character.is_main}}
            <span class="badge main-badge">Main Character</span>
          {{/if}}
        </h2>

        <div class="owner-actions">
          {{#if this.currentUser.admin}}
            <DButton
              @action={{this.adminEdit}}
              @label="discourse_size.admin_edit"
              class="btn-default"
            />
          {{/if}}

          {{#if this.canEdit}}
            <DButton
              @action={{fn @onUpdate @character}}
              @label="discourse_size.edit"
              class="btn-default"
            />
          {{/if}}

          {{#if this.showActions}}
            <DiscourseSizeCharacterActions
              @character={{@character}}
              @userPoints={{@userPoints}}
              @onAction={{@onAction}}
              @isCurrentUser={{@isCurrentUser}}
            />
          {{/if}}

          {{#if @showReorderHandle}}
            <div class="character-drag-handle">
              {{d-icon "bars"}}
            </div>
          {{/if}}
        </div>
      </div>

      <div class="character-header-meta">
        <span class="header-meta-card size">
          <span class="label">Size</span>
          <span class="value">{{this.formattedSize}}</span>
        </span>
        {{#if @character.gender}}
          <span class="header-meta-card gender">
            <span class="label">Gender</span>
            <span class="value">{{@character.gender}}</span>
          </span>
        {{/if}}
        {{#if @character.pronouns}}
          <span class="header-meta-card pronouns">
            <span class="label">Pronouns</span>
            <span class="value">{{@character.pronouns}}</span>
          </span>
        {{/if}}
        {{#if @character.age}}
          <span class="header-meta-card age">
            <span class="label">Age</span>
            <span class="value">{{@character.age}}</span>
          </span>
        {{/if}}
        {{#if @character.species}}
          <span class="header-meta-card species">
            <span class="label">Species</span>
            <span class="value">{{@character.species}}</span>
          </span>
        {{/if}}
      </div>

      {{#if this.isAnimating}}
        <div class="character-size-row">
          <div class="growth-stats">
            {{#if this.activeAction}}
              <div class="growth-status-label">
                <span
                  class="{{if
                      (eq this.activeActionType 'grow')
                      'growing'
                      'shrinking'
                    }}"
                >
                  {{#if (eq this.activeActionType "grow")}}
                    {{d-icon "arrow-up"}}
                    {{i18n
                      "discourse_size.currently_growing_from"
                      item=this.activeActionItemName
                    }}
                  {{else}}
                    {{d-icon "arrow-down"}}
                    {{i18n
                      "discourse_size.currently_shrinking_from"
                      item=this.activeActionItemName
                    }}
                  {{/if}}
                </span>

                {{#if this.timeRemaining}}
                  <div class="growth-meta">
                    <span class="time-remaining">
                      {{d-icon "clock"}}
                      {{this.timeRemaining}}
                      remaining
                    </span>
                  </div>
                {{/if}}
              </div>

              <div class="progress-bar-wrapper">
                <span class="size-bound">{{this.formattedStartSize}}</span>
                <div class="progress-bar-mini">
                  <div
                    class="progress-fill"
                    style={{html-safe
                      (concat "width: " this.progressPercent "%")
                    }}
                  ></div>
                </div>
                <span class="size-bound">{{this.formattedTargetSize}}</span>
              </div>
            {{/if}}

            {{#if this.formattedQueuedActions}}
              <div class="queued-actions">
                {{i18n "discourse_size.queued"}}
                {{this.formattedQueuedActions}}
              </div>
            {{/if}}
          </div>
        </div>
      {{/if}}
    </div>
  </div>

  {{#if this.hasDescription}}
    <div class="character-description">
      {{#if @character.show_comparison}}
        <div class="character-comparison">
          {{this.comparisonText}}
          {{#if this.growthComparisonText}}
            <span class="growth-comparison">
              {{this.growthComparisonText}}</span>
          {{/if}}
        </div>
      {{/if}}

      {{#if @character.description}}
        <div class="character-full-description">{{@character.description}}</div>
      {{/if}}

      {{#if @character.info_post}}
        <a href={{@character.info_post}} target="_blank" class="info-link">
          More info about this character.</a>
      {{/if}}
    </div>
  {{/if}}

  {{#if @character.actions.length}}
    <div class="character-activity">
      <div class="activity-header">
        <h5>{{i18n "discourse_size.recent_activity"}}
          ({{@character.actions.length}}
          total)</h5>
        <DButton
          @action={{this.showGrowthGraph}}
          @icon="chart-line"
          @title="discourse_size.show_size_history"
          class="btn-flat show-graph-btn"
        />
      </div>
      <ul>
        {{#each this.recentActions as |action|}}
          <li>
            <span class="activity-date">{{format-date
                action.created_at
                format="medium"
              }}
              ago</span>
            &mdash;
            <span class="activity-text">
              <strong>
                <LinkTo
                  @route="user.index"
                  @model={{action.user.username}}
                >{{action.user.username}}</LinkTo>
              </strong>
              {{#if action.parent_action_id}}
                {{i18n "discourse_size.activity.used"}}
                <LinkTo
                  @route="size-shop"
                  class="item-link"
                >{{action.item_name}}</LinkTo>
                {{#if (eq action.parent_action_type "grow")}}
                  {{i18n "discourse_size.activity.to_grow"}}
                {{else}}
                  {{i18n "discourse_size.activity.to_shrink"}}
                {{/if}}
                <LinkTo
                  @route="user.characters.index"
                  @model={{action.target_owner_username}}
                >{{action.target_character_name}}</LinkTo>
                {{i18n "discourse_size.activity.by"}}
                {{format-size
                  (abs action.parent_size_change)
                  @character.measurement_system
                }},
                {{i18n "discourse_size.activity.causing"}}
                <LinkTo
                  @route="user.characters.index"
                  @model={{action.character_owner_username}}
                >{{@character.name}}</LinkTo>
                {{i18n "discourse_size.activity.to"}}
                {{action.action_type}}
                {{i18n "discourse_size.activity.by"}}
                {{format-size
                  (abs action.size_change)
                  @character.measurement_system
                }}
              {{else if
                (or
                  (eq action.action_type "grow")
                  (eq action.action_type "shrink")
                )
              }}
                {{#if action.item_name}}
                  {{i18n "discourse_size.activity.used"}}
                  <LinkTo
                    @route="size-shop"
                    class="item-link"
                  >{{action.item_name}}</LinkTo>
                  {{i18n
                    (concat "discourse_size.activity.to_" action.action_type)
                  }}
                {{else}}
                  {{i18n
                    (concat
                      "discourse_size.activity."
                      (if (eq action.action_type "grow") "grew" "shrunk")
                    )
                  }}
                {{/if}}
                <LinkTo
                  @route="user.characters.index"
                  @model={{action.character_owner_username}}
                >{{@character.name}}</LinkTo>
                {{i18n "discourse_size.activity.by"}}
                {{format-size
                  (abs action.size_change)
                  @character.measurement_system
                }}{{#if action.child_action_id}},
                  {{i18n "discourse_size.activity.causing"}}
                  <LinkTo
                    @route="user.characters.index"
                    @model={{action.child_character_owner_username}}
                  >{{action.child_character_name}}</LinkTo>
                  {{i18n "discourse_size.activity.to"}}
                  {{action.child_action_type}}
                  {{i18n "discourse_size.activity.by"}}
                  {{format-size
                    (abs action.child_size_change)
                    @character.measurement_system
                  }}
                {{/if}}
              {{else if (eq action.action_type "reset")}}
                {{i18n
                  "discourse_size.activity.reset"
                  character=@character.name
                }}
              {{else if (eq action.action_type "set_size")}}
                {{i18n "discourse_size.activity.set_size_to"}}
                {{format-size
                  @character.current_size
                  @character.measurement_system
                }}
              {{else if (eq action.action_type "boost_speed")}}
                {{i18n "discourse_size.activity.boost_speed"}}
                +{{action.size_change}}% / day
              {{else}}
                {{i18n
                  "discourse_size.activity.unknown"
                  character=@character.name
                  type=action.action_type
                }}
              {{/if}}
            </span>
          </li>
        {{/each}}
      </ul>
    </div>
  {{/if}}
</div>