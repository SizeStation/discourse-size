<div class="discourse-size-character-card {{if @character.is_main 'is-main'}}">
  <div class="character-header-layout">
    <div class="character-picture-wrapper">
      {{#if @character.picture}}
        <img
          src={{@character.picture}}
          alt={{@character.name}}
          class="character-picture"
        />
      {{else}}
        <div class="character-picture-placeholder">No Image</div>
      {{/if}}
    </div>

    <div class="character-info">
      <div class="character-header">
        <h4>
          <strong>{{@character.name}}</strong>
          {{#if @character.is_main}}
            <span class="badge main-badge">Main Character</span>
          {{/if}}
        </h4>

        <div class="owner-actions">
          {{#if
            (and
              this.currentUser.admin
              (not (eq @character.character_type "freeform"))
            )
          }}
            <DButton
              @action={{this.adminEdit}}
              @label="discourse_size.admin_edit"
              class="btn-default"
            />
          {{/if}}

          {{#if this.canEdit}}
            <DButton
              @action={{fn @onUpdate @character}}
              @label="discourse_size.edit"
              class="btn-default"
            />
          {{/if}}
        </div>
      </div>

      <div class="character-header-meta">
        {{#if @character.gender}}
          <span class="header-meta-card gender">
            <span class="label">Gender:</span>
            <span class="value">{{@character.gender}}</span>
          </span>
        {{/if}}
        {{#if @character.pronouns}}
          <span class="header-meta-card pronouns">
            <span class="label">Pronouns:</span>
            <span class="value">{{@character.pronouns}}</span>
          </span>
        {{/if}}
        {{#if @character.age}}
          <span class="header-meta-card age">
            <span class="label">Age:</span>
            <span class="value">{{@character.age}}</span>
          </span>
        {{/if}}
      </div>

      <div class="character-size-row">
        <p class="character-size">
          <span>Size:</span>
          <span class="current-size-display">{{this.formattedSize}}</span>
          {{#if this.showSpeed}}
            <span class="speed-limit">({{this.formattedGrowthRate}})</span>
          {{/if}}
        </p>

        {{#if this.isAnimating}}
          <div class="growth-stats">
            <div class="progress-bar-mini">
              <div
                class="progress-fill"
                style={{html-safe (concat "width: " this.progressPercent "%")}}
              ></div>
            </div>
            <span class="target-size-display">
              Target:
              <strong>{{this.formattedTargetSize}}</strong>
              ({{this.progressPercent}}%)
            </span>
            <span class="time-remaining">
              {{d-icon "clock"}}
              {{this.timeRemaining}}
            </span>
          </div>
        {{/if}}
      </div>
    </div>
  </div>

  <div class="character-description">
    {{#if @character.show_comparison}}
      <div class="character-comparison">
        {{this.comparisonText}}
        {{#if this.growthComparisonText}}
          <span class="growth-comparison"> {{this.growthComparisonText}}</span>
        {{/if}}
      </div>
    {{/if}}

    {{#if @character.description}}
      <p class="character-full-description">{{@character.description}}</p>
    {{/if}}

    {{#if @character.info_post}}
      <a href={{@character.info_post}} target="_blank" class="info-link">
        More info about this character.</a>
    {{/if}}
  </div>

  <div class="character-actions">
    {{#if this.canGrowOrShrink}}
      <DiscourseSizeCharacterActions
        @character={{@character}}
        @userPoints={{@userPoints}}
        @onAction={{@onAction}}
        @isCurrentUser={{@isCurrentUser}}
      />
    {{/if}}
  </div>

  {{#if @character.actions.length}}
    <div class="character-activity">
      <div class="activity-header">
        <h5>{{i18n "discourse_size.recent_activity"}}</h5>
        <DButton
          @action={{this.showGrowthGraph}}
          @icon="chart-line"
          @title="discourse_size.show_size_history"
          class="btn-flat show-graph-btn"
        />
      </div>
      <ul>
        {{#each @character.actions as |action|}}
          <li>
            <span class="activity-date">{{format-date
                action.created_at
                format="medium"
              }}
              ago</span>
            &mdash;
            <a href="/u/{{action.user.username}}">{{action.user.username}}</a>
            {{#if (eq action.action_type "grow")}}
              grew
              {{@character.name}}
              by
              {{format-size
                (abs action.size_change)
                @character.measurement_system
              }}
            {{else if (eq action.action_type "shrink")}}
              shrunk
              {{@character.name}}
              by
              {{format-size
                (abs action.size_change)
                @character.measurement_system
              }}
            {{else if (eq action.action_type "reset")}}
              reset
              {{@character.name}}'s size
            {{else if (eq action.action_type "boost_speed")}}
              increased
              {{@character.name}}'s growth speed by
              {{action.size_change}}%!
            {{else}}
              {{action.action_type}}
              {{@character.name}}
            {{/if}}
          </li>
        {{/each}}
      </ul>
    </div>
  {{/if}}
</div>