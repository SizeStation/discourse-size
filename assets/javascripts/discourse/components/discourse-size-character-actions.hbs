{{#if this.isGame}}
  {{#if this.isBlocked}}
    <DButton
      class="btn-danger disabled open-inventory-btn"
      @disabled={{true}}
    >You're Blocked</DButton>
  {{else}}
    <DButton
      @action={{this.openInventoryModal}}
      class="btn-primary open-inventory-btn"
    >Use Items</DButton>
  {{/if}}
{{/if}}