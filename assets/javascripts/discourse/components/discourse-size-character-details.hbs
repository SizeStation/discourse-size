<div class="discourse-size-character-details">
  <div class="details-header">
    <LinkTo @route="user.characters.index" class="back-link">
      {{d-icon "arrow-left"}}
      Back to characters
    </LinkTo>
    <h2>
      {{@character.name}}
      {{#if (eq @character.character_type "freeform")}}
        <span class="badge freeform-badge">Freeform</span>
      {{/if}}
    </h2>
  </div>

  <div class="details-grid">
    <div class="details-main-info">
      <div class="details-picture-section">
        {{#if @character.picture}}
          <img
            src={{@character.picture}}
            alt={{@character.name}}
            class="details-picture"
          />
        {{else}}
          <div class="details-picture-placeholder">No Image</div>
        {{/if}}
      </div>

      <div class="details-stats-section">
        <div class="stat-item">
          <label>Current Size</label>
          <div class="value big">
            {{this.formattedSize}}
            {{#if this.showSpeed}}
              <span class="speed-limit">({{this.formattedGrowthRate}})</span>
            {{/if}}
          </div>
          <div class="comparison-text">
            {{this.comparisonText}}
            {{#if this.growthComparisonText}}
              <span class="growth-comparison"> {{this.growthComparisonText}}</span>
            {{/if}}
          </div>
        </div>

        {{#if this.isAnimating}}
          <div class="stat-item animation-info">
            <label>Growth Progress</label>
            <div class="progress-bar-container">
              <div
                class="progress-fill"
                style={{html-safe (concat "width: " this.progressPercent "%")}}
              ></div>
            </div>
            <div class="progress-info">
              Target:
              <strong>{{this.formattedTargetSize}}</strong>
              ({{this.progressPercent}}%)
              <span class="time-remaining">
                {{d-icon "clock"}}
                {{this.timeRemaining}}
              </span>
            </div>
          </div>
        {{/if}}
      </div>

      {{#if @character.info_post}}
        <div class="details-link-section">
          <DButton
            @href={{@character.info_post}}
            @label="discourse_size.view_info_post"
            @icon="external-link-alt"
            class="btn-default btn-large"
          />
        </div>
      {{/if}}
    </div>

    <div class="details-side-panel">
      {{#if this.showActions}}
        <div class="details-actions-section">
          <div class="action-card grow-card">
            <h3>Actions</h3>
            <DiscourseSizeCharacterActions
              @character={{@character}}
              @userPoints={{@userPoints}}
              @onAction={{@onAction}}
              @isCurrentUser={{@isCurrentUser}}
            />
          </div>
        </div>
      {{/if}}

      {{#if @isCurrentUser}}
        <div class="action-card management-card">
          <h3>Management</h3>
          <div class="owner-buttons">
            {{#unless @character.is_main}}
              <DButton
                @action={{this.setMain}}
                @label="discourse_size.set_main"
                class="btn-default"
              />
            {{/unless}}
            <DButton
              @action={{fn @onUpdate @character}}
              @icon="pencil-alt"
              @label="discourse_size.edit"
              class="btn-primary"
            />
            <DButton
              @action={{fn @onDelete @character}}
              @icon="trash-alt"
              @label="discourse_size.delete"
              class="btn-danger"
            />
          </div>
        </div>
      {{/if}}
    </div>
  </div>

  {{#if @character.actions.length}}
    <div class="details-activity-section">
      <h3>Recent Activity</h3>
      <div class="activity-list">
        {{#each @character.actions as |action|}}
          <div class="activity-item">
            <span class="activity-date">{{format-date
                action.created_at
                format="medium"
              }}
              ago</span>
            <span class="activity-text">
              <strong>{{action.user.username}}</strong>
              {{#if (eq action.action_type "grow")}}
                grew
                {{@character.name}}
                by
                {{format-size
                  (abs action.size_change)
                  @character.measurement_system
                }}
              {{else if (eq action.action_type "shrink")}}
                shrunk
                {{@character.name}}
                by
                {{format-size
                  (abs action.size_change)
                  @character.measurement_system
                }}
              {{else if (eq action.action_type "reset")}}
                reset
                {{@character.name}}'s size
              {{else if (eq action.action_type "boost_speed")}}
                increased
                {{@character.name}}'s growth speed by
                {{action.size_change}}%!
              {{else if (eq action.action_type "set_size")}}
                set
                {{@character.name}}'s size to
                {{format-size
                  @character.current_size
                  @character.measurement_system
                }}
              {{else}}
                {{action.action_type}}
                {{@character.name}}
              {{/if}}
            </span>
          </div>
        {{/each}}
      </div>
    </div>
  {{/if}}
</div>