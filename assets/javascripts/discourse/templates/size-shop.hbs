<div class="size-shop-container">
  <div class="shop-header">
    <div class="shop-title">
      <h1>{{this.shopName}}</h1>
    </div>
    <div class="shop-meta">
      {{#if this.currentUser.admin}}
        <DButton
          @icon="plus"
          @label="discourse_size.shop.add_item"
          @action={{this.addShopItem}}
          class="btn-default add-item-btn"
        />
        <DButton
          @icon="plus"
          @icon="heading"
          @label="discourse_size.shop.add_header"
          @action={{this.addSectionHeader}}
          class="btn-default add-header-btn"
        />
      {{/if}}
      <DButton
        @label="discourse_size.inventory.my_inventory"
        @icon="inbox"
        @action={{this.showInventory}}
        class="btn-default"
      />
      <DButton @action={{this.showPointHistory}} class="btn-default">
        <span>Balance:
          {{this.currentPoints}}
          {{i18n "discourse_size.admin_points"}}</span>
      </DButton>
      <DButton
        @label={{if
          (eq this.currentUser.discourse_size_daily_reward_status "available")
          "discourse_size.shop.claim_reward"
          "discourse_size.shop.earn_coins"
        }}
        @action={{this.showQuests}}
        class="btn-default claim-reward-btn"
      />
    </div>
  </div>

  <div class="shop-grid-wrapper">
    {{#if this.currentUser.admin}}
      <DiscourseSizeReorderableList
        @enabled={{true}}
        @onReorder={{this.reorderItems}}
        @handle=".drag-handle"
        class="shop-grid"
      >
        {{#each this.items as |item|}}
          {{#if (eq item.item_type "header")}}
            <div
              class="shop-section-header"
              style={{html-safe (concat "color: " item.color)}}
            >
              <div class="header-left">
                <div class="drag-handle">
                  {{d-icon "grip-lines"}}
                </div>
                <h2>{{item.name}}</h2>
              </div>
              <div class="header-actions">
                <DButton
                  @icon="pencil"
                  @action={{fn this.editShopItem item}}
                  class="btn-flat"
                />
              </div>
            </div>
          {{else}}
            <div
              class="shop-item-card
                {{if (gt item.price this.currentPoints) 'expensive'}}"
            >
              <div class="item-header">
                {{#if item.picture}}
                  <div class="item-image">
                    <img src={{item.picture}} alt={{item.name}} />
                  </div>
                {{/if}}
                <div class="drag-handle">
                  {{d-icon "grip-lines"}}
                </div>
              </div>
              <div class="item-info">
                <h2 class="item-name">{{item.name}}</h2>
                <div class="item-stats">
                  <span
                    class="stat stock {{if (eq item.stock 0) 'out-of-stock'}}"
                  >
                    {{i18n "discourse_size.shop.stats.stock"}}:
                    {{if
                      (eq item.stock -1)
                      (i18n "discourse_size.shop.stats.infinite")
                      item.stock
                    }}
                  </span>
                  {{#unless item.enabled}}
                    <span class="stat disabled-label">{{i18n
                        "discourse_size.shop.stats.disabled"
                      }}</span>
                  {{/unless}}
                </div>
                <p class="item-description">{{item.description}}</p>
              </div>
              <div class="item-footer">
                <span class="item-price">{{item.price}} Coins</span>
                <div class="actions">
                  <DButton
                    @icon="pencil"
                    @action={{fn this.editShopItem item}}
                    class="btn-default edit-btn"
                  />
                  <DButton
                    @label={{if
                      (gt item.price this.currentPoints)
                      "discourse_size.shop.too_expensive"
                      "discourse_size.shop.purchase"
                    }}
                    @action={{fn this.purchaseItem item}}
                    @disabled={{or
                      (gt item.price this.currentPoints)
                      (eq this.purchasing item.key)
                    }}
                    class={{if
                      (gt item.price this.currentPoints)
                      "btn-danger purchase-btn"
                      "btn-primary purchase-btn"
                    }}
                  />
                </div>
              </div>
            </div>
          {{/if}}
        {{/each}}
      </DiscourseSizeReorderableList>
    {{else}}
      <div class="shop-grid">
        {{#each this.items as |item|}}
          {{#if (eq item.item_type "header")}}
            <div
              class="shop-section-header"
              style={{html-safe (concat "color: " item.color)}}
            >
              <h2>{{item.name}}</h2>
            </div>
          {{else}}
            <div
              class="shop-item-card
                {{if (gt item.price this.currentPoints) 'expensive'}}"
            >
              {{#if item.picture}}
                <div class="item-image">
                  <img src={{item.picture}} alt={{item.name}} />
                </div>
              {{/if}}
              <div class="item-info">
                <h2 class="item-name">{{item.name}}</h2>
                <div class="item-stats">
                  <span
                    class="stat stock {{if (eq item.stock 0) 'out-of-stock'}}"
                  >
                    {{i18n "discourse_size.shop.stats.stock"}}:
                    {{if
                      (eq item.stock -1)
                      (i18n "discourse_size.shop.stats.infinite")
                      item.stock
                    }}
                  </span>
                  {{#unless item.enabled}}
                    <span class="stat disabled-label">{{i18n
                        "discourse_size.shop.stats.disabled"
                      }}</span>
                  {{/unless}}
                </div>
                <p class="item-description">{{item.description}}</p>
              </div>
              <div class="item-footer">
                <span class="item-price">{{item.price}} Coins</span>
                <div class="actions">
                  <DButton
                    @label={{if
                      (gt item.price this.currentPoints)
                      "discourse_size.shop.too_expensive"
                      "discourse_size.shop.purchase"
                    }}
                    @action={{fn this.purchaseItem item}}
                    @disabled={{or
                      (gt item.price this.currentPoints)
                      (eq this.purchasing item.key)
                    }}
                    class={{if
                      (gt item.price this.currentPoints)
                      "btn-danger purchase-btn"
                      "btn-primary purchase-btn"
                    }}
                  />
                </div>
              </div>
            </div>
          {{/if}}
        {{/each}}
      </div>
    {{/if}}
  </div>
</div>