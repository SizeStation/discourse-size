<div class="container size-leaderboard">
  <div class="leaderboard-header">
    <h2>Size Leaderboard</h2>
    <div class="sort-controls">
      <DButton
        @action={{fn this.setSort "biggest"}}
        @label="discourse_size.leaderboard.biggest"
        class={{if (eq this.sort "biggest") "btn-primary" "btn-default"}}
      />
      <DButton
        @action={{fn this.setSort "smallest"}}
        @label="discourse_size.leaderboard.smallest"
        class={{if (eq this.sort "smallest") "btn-primary" "btn-default"}}
      />
    </div>
  </div>

  <div class="leaderboard-list">
    <table class="table">
      <thead>
        <tr>
          <th>Rank</th>
          <th>Character</th>
          <th>Owner</th>
          <th>Size</th>
          <th>Trend</th>
        </tr>
      </thead>
      <tbody>
        {{#each this.characters as |character index|}}
          <tr>
            <td>#{{add index 1}}</td>
            <td>
              <div class="lb-character-info">
                {{#if character.picture}}
                  <a
                    href="/u/{{character.user.username}}/characters"
                    class="lb-picture-link"
                  >
                    <img
                      src={{character.picture}}
                      alt={{character.name}}
                      class="lb-picture"
                    />
                  </a>
                {{/if}}
                <a
                  href="/u/{{character.user.username}}/characters"
                >{{character.name}}</a>
              </div>
            </td>
            <td>
              <a
                href="/u/{{character.user.username}}"
              >{{character.user.username}}</a>
            </td>
            <td class="lb-size-column">
              <div class="lb-size-wrapper">
                <div class="lb-current-size">
                  {{format-size character.current_size}}
                </div>
                {{#if character.is_animating}}
                  <div
                    class="lb-growth-info
                      {{if character.is_growing 'growing' 'shrinking'}}"
                  >
                    <span class="lb-status-label">
                      {{#if character.is_growing}}
                        {{d-icon "arrow-up"}}
                        Currently growing
                      {{else}}
                        {{d-icon "arrow-down"}}
                        Currently shrinking
                      {{/if}}
                      {{#if character.time_remaining}}
                        <div></div>
                        <div class="growth-meta">
                          <span class="time-remaining">
                            {{d-icon "clock"}}
                            {{character.time_remaining}}
                            remaining
                          </span>
                        </div>
                      {{/if}}
                    </span>
                    <span class="lb-target-size">
                      Target:
                      {{format-size character.target_size}}
                    </span>
                  </div>
                {{/if}}
              </div>
            </td>
            <td class="lb-trend-column">
              {{#if (not (eq character.trend_diff 0))}}
                <div
                  class="lb-trend-wrapper
                    {{if (gt character.trend_diff 0) 'climbing' 'descending'}}"
                >
                  {{#if (gt character.trend_diff 0)}}
                    {{d-icon "arrow-up"}}
                  {{else}}
                    {{d-icon "arrow-down"}}
                  {{/if}}
                  <span class="trend-percent">
                    {{abs character.trend_percent}}%
                  </span>
                </div>
              {{/if}}
            </td>
          </tr>
        {{else}}
          <tr>
            <td colspan="4" class="no-results">No characters found for this
              sorting.</td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>